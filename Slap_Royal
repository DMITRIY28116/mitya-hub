local Gui = Instance.new("ScreenGui")
Gui.Name = "FoxCombatAndEsp"
Gui.ResetOnSpawn = false
Gui.Parent = LocalPlayer:WaitForChild("PlayerGui")

local Frame = Instance.new("Frame")
Frame.Size = UDim2.new(0, 250, 0, 170) -- Размер под 4 кнопки
Frame.Position = UDim2.new(0, 15, 0.2, 0)
Frame.BackgroundColor3 = Color3.fromRGB(18, 18, 25)
Frame.Parent = Gui
Instance.new("UICorner", Frame).CornerRadius = UDim.new(0, 8)

-- Драг
local Dragging, DragStart, StartPos
Frame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        Dragging = true; DragStart = input.Position; StartPos = Frame.Position
    end
end)
Frame.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then Dragging = false end
end)
UserInputService.InputChanged:Connect(function(input)
    if Dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local Delta = input.Position - DragStart
        Frame.Position = UDim2.new(StartPos.X.Scale, StartPos.X.Offset + Delta.X, StartPos.Y.Scale, StartPos.Y.Offset + Delta.Y)
    end
end)

local Title = Instance.new("TextLabel")
Title.Size = UDim2.new(1, 0, 0, 20)
Title.BackgroundTransparency = 1
Title.Text = "COMBAT & ESP"
Title.TextColor3 = Color3.fromRGB(0, 255, 120)
Title.TextScaled = true
Title.Font = Enum.Font.GothamBold
Title.Parent = Frame

local function CreateBtn(name, yPos, color)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0.9, 0, 0, 28)
    btn.Position = UDim2.new(0.05, 0, 0, yPos)
    btn.BackgroundColor3 = color
    btn.Text = name
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.TextScaled = true
    btn.Font = Enum.Font.GothamSemibold
    btn.Parent = Frame
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)
    return btn
end

local ReachBtn = CreateBtn("REACH (15st): OFF", 28, Color3.fromRGB(30, 30, 45))
local AuraBtn = CreateBtn("KILL AURA: OFF", 60, Color3.fromRGB(30, 30, 45))
local PlayerEspBtn = CreateBtn("PLAYER ESP: OFF", 92, Color3.fromRGB(30, 30, 45))
local ItemEspBtn = CreateBtn("ITEM ESP: OFF", 124, Color3.fromRGB(30, 30, 45))

-- ========================================================
-- КНОПКИ
-- ========================================================
ReachBtn.MouseButton1Click:Connect(function()
    ReachActive = not ReachActive
    ReachBtn.Text = "REACH (15st): " .. (ReachActive and "ON" or "OFF")
    ReachBtn.BackgroundColor3 = ReachActive and Color3.fromRGB(0, 140, 70) or Color3.fromRGB(30, 30, 45)
    ApplyGrip()
end)

AuraBtn.MouseButton1Click:Connect(function()
    AuraActive = not AuraActive
    AuraBtn.Text = "KILL AURA: " .. (AuraActive and "ON" or "OFF")
    AuraBtn.BackgroundColor3 = AuraActive and Color3.fromRGB(140, 20, 20) or Color3.fromRGB(30, 30, 45)
end)

PlayerEspBtn.MouseButton1Click:Connect(function()
    PlayerEspActive = not PlayerEspActive
    PlayerEspBtn.Text = "PLAYER ESP: " .. (PlayerEspActive and "ON" or "OFF")
    PlayerEspBtn.BackgroundColor3 = PlayerEspActive and Color3.fromRGB(0, 80, 170) or Color3.fromRGB(30, 30, 45)
    UpdatePlayerEsp()
end)

ItemEspBtn.MouseButton1Click:Connect(function()
    ItemEspActive = not ItemEspActive
    ItemEspBtn.Text = "ITEM ESP: " .. (ItemEspActive and "ON" or "OFF")
    ItemEspBtn.BackgroundColor3 = ItemEspActive and Color3.fromRGB(150, 100, 0) or Color3.fromRGB(30, 30, 45)
    if ItemEspActive then EnableItemEsp() else DisableItemEsp() end
end)
