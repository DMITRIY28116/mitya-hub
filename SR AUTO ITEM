-- Поиск ближайшего предмета
local function FindNearestItem()
    local nearest = nil
    local minDist = math.huge
    
    pcall(function()
        local char = LocalPlayer.Character
        if not char or not char:FindFirstChild("HumanoidRootPart") then return end
        local myPos = char.HumanoidRootPart.Position
        
        for _, obj in ipairs(workspace:GetDescendants()) do
            if obj:IsA("Tool") then
                local isHeld = false
                if obj.Parent and obj.Parent:IsA("Model") and obj.Parent:FindFirstChild("Humanoid") then
                    isHeld = true
                end
                
                if not isHeld then
                    local handle = obj:FindFirstChild("Handle")
                    if handle then
                        local dist = (myPos - handle.Position).Magnitude
                        if dist < minDist then
                            minDist = dist
                            nearest = obj
                        end
                    end
                end
            end
        end
    end)
    
    return nearest
end

-- Луп сбора
local function FastCollectLoop()
    -- Включаем ноклип на ВЕСЬ процесс фарма (чтобы не провалиться)
    StartNoclip()
    
    while AutoCollectActive do
        task.wait(0.5)
        pcall(function()
            -- КД после 3 предметов
            if GrabbedCount >= MaxGrabsBeforePause then
                Status.Text = "Отдых... (" .. PauseTime .. " сек)"
                Status.TextColor3 = Color3.fromRGB(255, 200, 0)
                task.wait(PauseTime)
                GrabbedCount = 0
            end
            
            local char = LocalPlayer.Character
            if not char or not char:FindFirstChild("HumanoidRootPart") or not char:FindFirstChild("Humanoid") then return end
            local root = char.HumanoidRootPart
            local hum = char.Humanoid
            
            local item = FindNearestItem()
            if item then
                local handle = item:FindFirstChild("Handle")
                if handle then
                    local dist = (root.Position - handle.Position).Magnitude
                    
                    -- 1. ПОЛЕТ (Если дальше 20 стадов)
                    if dist > StopDistance then
                        Status.Text = "Летим..."
                        hum.PlatformStand = true
                        
                        local direction = (handle.Position - root.Position).Unit
                        local flyTarget = handle.Position - (direction * StopDistance) + Vector3.new(0, 5, 0)
                        
                        root.AssemblyLinearVelocity = direction * FlySpeed
                        
                        local timeout = 0
                        while (root.Position - flyTarget).Magnitude > 5 do
                            local dt = RunService.Heartbeat:Wait()
                            timeout = timeout + dt
                            if timeout > 5 then break end
                            if not AutoCollectActive then break end
                            local newDir = (flyTarget - root.Position).Unit
                            root.AssemblyLinearVelocity = newDir * FlySpeed
                        end
                        
                        -- 2. ОСТАНОВКА В ВОЗДУХЕ (Ноклип всё ещё включен, ты не падаешь)
                        root.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
                        root.Velocity = Vector3.new(0, 0, 0)
                        hum.PlatformStand = false -- Выключаем, чтобы можно было идти MoveTo
                        
                        -- 3. СИНХРОНИЗАЦИЯ С СЕРВЕРОМ
                        Status.Text = "Синхронизация..."
                        Status.TextColor3 = Color3.fromRGB(255, 100, 0)
                        task.wait(1.5)
                    end
                    
                    -- 4. ИДЕМ ПЕШКОМ ПО ВОЗДУХУ (MoveTo)
                    Status.Text = "Идем к предмету..."
                    Status.TextColor3 = Color3.fromRGB(0, 255, 120)
                    hum:MoveTo(handle.Position)
                    
                    local walkTimeout = 0
                    while (root.Position - handle.Position).Magnitude > 5 and walkTimeout < 3 do
                        task.wait(0.1)
                        walkTimeout = walkTimeout + 0.1
                        if not AutoCollectActive then break end
                    end
                    
                    task.wait(0.2)
                    
                    -- 5. ХВАТАЕМ
                    Status.Text = "Берем!"
                    local prompt = item:FindFirstChild("ProximityPrompt", true)
                    if prompt then
                        pcall(function() fireproximityprompt(prompt) end)
                    else
                        pcall(function() keypress(0x46) task.wait(0.05) keyrelease(0x46) end)
                    end
                    
                    GrabbedCount = GrabbedCount + 1
                    Status.Text = "Взято: " .. GrabbedCount .. "/" .. MaxGrabsBeforePause
                    
                    task.wait(0.5)
                end
            end
        end)
    end
    
    -- Выключаем ноклип ТОЛЬКО когда остановили фарм
    Status.Text = "Статус: Готов"
    Status.TextColor3 = Color3.fromRGB(200, 200, 200)
    GrabbedCount = 0
    StopNoclip()
end

-- Луп юза
local function AutoUseLoop()
    while task.wait(1.5) do
        pcall(function()
            local char = LocalPlayer.Character
            if not char or not char:FindFirstChild("Humanoid") then return end
            local hum = char.Humanoid
            local backpack = LocalPlayer.Backpack
            
            for _, tool in ipairs(backpack:GetChildren()) do
                if tool:IsA("Tool") then
                    local name = tool.Name:lower()
                    local isBomb = name:find("bomb") or name:find("tnt") or name:find("dynamite") or name:find("grenade") or name:find("explode") or name:find("c4")
                    
                    if AutoBuffActive and not isBomb then
                        hum:EquipTool(tool)
                        task.wait(0.1)
                        tool:Activate()
                        task.wait(0.3)
                        hum:UnequipTools()
                        task.wait(0.05)
                    end
                    
                    if AutoBombActive and isBomb then
                        hum:EquipTool(tool)
                        task.wait(0.1)
                        tool:Activate()
                        task.wait(0.3)
                        hum:UnequipTools()
                        task.wait(0.05)
                    end
                end
            end
        end)
    end
end

task.spawn(AutoUseLoop)

