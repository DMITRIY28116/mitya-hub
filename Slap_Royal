-- Slap Royale Static Reach + 360 Aura + ESP (Stable, No Crash)
if not game:IsLoaded() then game.Loaded:Wait() end
task.wait(2)

local success, err = pcall(function()
    local Players = game:GetService("Players")
    local RunService = game:GetService("RunService")
    local UserInputService = game:GetService("UserInputService")
    local VirtualUser = game:GetService("VirtualUser")

    local LocalPlayer = Players.LocalPlayer
    local ReachActive = false
    local AuraActive = false
    local EspActive = false
    local ReachDistance = 15 

    -- GUI
    local Gui = Instance.new("ScreenGui")
    Gui.Name = "FoxSlapStable"
    Gui.ResetOnSpawn = false
    Gui.Parent = LocalPlayer:WaitForChild("PlayerGui")

    local Frame = Instance.new("Frame")
    Frame.Size = UDim2.new(0, 250, 0, 180)
    Frame.Position = UDim2.new(0, 15, 0.3, 0)
    Frame.BackgroundColor3 = Color3.fromRGB(18, 18, 25)
    Frame.Parent = Gui
    Instance.new("UICorner", Frame).CornerRadius = UDim.new(0, 8)

    -- Драг
    local Dragging, DragStart, StartPos
    Frame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            Dragging = true; DragStart = input.Position; StartPos = Frame.Position
        end
    end)
    Frame.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then Dragging = false end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if Dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local Delta = input.Position - DragStart
            Frame.Position = UDim2.new(StartPos.X.Scale, StartPos.X.Offset + Delta.X, StartPos.Y.Scale, StartPos.Y.Offset + Delta.Y)
        end
    end)

    local Title = Instance.new("TextLabel")
    Title.Size = UDim2.new(1, 0, 0, 25)
    Title.BackgroundTransparency = 1
    Title.Text = "SLAP FOX MOD"
    Title.TextColor3 = Color3.fromRGB(0, 255, 120)
    Title.TextScaled = true
    Title.Font = Enum.Font.GothamBold
    Title.Parent = Frame

    local ReachBtn = Instance.new("TextButton")
    ReachBtn.Size = UDim2.new(0.9, 0, 0, 30)
    ReachBtn.Position = UDim2.new(0.05, 0, 0, 30)
    ReachBtn.BackgroundColor3 = Color3.fromRGB(30, 30, 45)
    ReachBtn.Text = "REACH (15st): OFF"
    ReachBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    ReachBtn.TextScaled = true
    ReachBtn.Font = Enum.Font.GothamSemibold
    ReachBtn.Parent = Frame
    Instance.new("UICorner", ReachBtn).CornerRadius = UDim.new(0, 6)

    local AuraBtn = Instance.new("TextButton")
    AuraBtn.Size = UDim2.new(0.9, 0, 0, 30)
    AuraBtn.Position = UDim2.new(0.05, 0, 0, 68)
    AuraBtn.BackgroundColor3 = Color3.fromRGB(30, 30, 45)
    AuraBtn.Text = "KILL AURA: OFF"
    AuraBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    AuraBtn.TextScaled = true
    AuraBtn.Font = Enum.Font.GothamSemibold
    AuraBtn.Parent = Frame
    Instance.new("UICorner", AuraBtn).CornerRadius = UDim.new(0, 6)

    local EspBtn = Instance.new("TextButton")
    EspBtn.Size = UDim2.new(0.9, 0, 0, 30)
    EspBtn.Position = UDim2.new(0.05, 0, 0, 106)
    EspBtn.BackgroundColor3 = Color3.fromRGB(30, 30, 45)
    EspBtn.Text = "PLAYER ESP: OFF"
    EspBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    EspBtn.TextScaled = true
    EspBtn.Font = Enum.Font.GothamSemibold
    EspBtn.Parent = Frame
    Instance.new("UICorner", EspBtn).CornerRadius = UDim.new(0, 6)

    -- ===== ЛОГИКА GRIP REACH (СТАТИЧЕСКИЙ) =====
    local OriginalGripC0 = nil

    local function ApplyGrip()
        local char = LocalPlayer.Character
        if not char then return end
        local arm = char:FindFirstChild("Right Arm") or char:FindFirstChild("RightHand")
        if not arm then return end
        local grip = arm:FindFirstChild("RightGrip")
        if grip then
            if not OriginalGripC0 then OriginalGripC0 = grip.C0 end
            if ReachActive then
                grip.C0 = OriginalGripC0 * CFrame.new(0, 0, -ReachDistance)
            elseif OriginalGripC0 then
                grip.C0 = OriginalGripC0
            end
        end
    end

    local function OnCharacterAdded(char)
        task.wait(1)
        local arm = char:WaitForChild("Right Arm", 5) or char:WaitForChild("RightHand", 5)
        if arm then
            arm.ChildAdded:Connect(function(child)
                if child.Name == "RightGrip" then
                    task.wait(0.1)
                    OriginalGripC0 = nil
                    ApplyGrip()
                end
            end)
        end
    end

    if LocalPlayer.Character then OnCharacterAdded(LocalPlayer.Character) end
    LocalPlayer.CharacterAdded:Connect(OnCharacterAdded)

    -- ===== ЛОГИКА КИЛЛ АУРЫ (360 ГРАДУСОВ, БЕЗ СПАМА В ФИЗИКУ) =====
    RunService.RenderStepped:Connect(function()
        if not AuraActive then return end
        pcall(function()
            local char = LocalPlayer.Character
            if not char or not char:FindFirstChild("HumanoidRootPart") then return end
            local myRoot = char.HumanoidRootPart
            
            for _, player in ipairs(Players:GetPlayers()) do
                if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
                    local targetRoot = player.Character.HumanoidRootPart
                    local dist = (myRoot.Position - targetRoot.Position).Magnitude
                    
                    -- Если враг в радиусе 15 стадов — бьем
                    if dist <= (ReachDistance + 2) then
                        VirtualUser:CaptureController()
                        VirtualUser:ClickButton1(Vector2.new())
                        break -- Бьем только одного ближайшего, чтобы не спамить кликами
                    end
                end
            end
        end)
    end)

    -- ===== ЛОГИКА ESP (HIGHLIGHT) =====
    local function UpdateEsp()
        for _, player in ipairs(Players:GetPlayers()) do
            if player ~= LocalPlayer then
                pcall(function()
                    if player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
                        local highlight = player.Character:FindFirstChild("FoxESP")
                        if EspActive then
                            if not highlight then
                                highlight = Instance.new("Highlight")
                                highlight.Name = "FoxESP"
                                highlight.FillColor = Color3.fromRGB(255, 0, 0)
                                highlight.FillTransparency = 0.5
                                highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
                                highlight.OutlineTransparency = 0
                                highlight.Parent = player.Character
                            end
                        else
                            if highlight then highlight:Destroy() end
                        end
                    end
                end)
            end
        end
    end

    Players.PlayerAdded:Connect(function(player)
        player.CharacterAdded:Connect(function(char)
            task.wait(2)
            UpdateEsp()
        end)
    end)
    
    Players.PlayerRemoving:Connect(function(player)
        pcall(function()
            if player.Character and player.Character:FindFirstChild("FoxESP") then
                player.Character.FoxESP:Destroy()
            end
        end)
    end)

    LocalPlayer.CharacterAdded:Connect(function()
        task.wait(2)
        UpdateEsp()
    end)

    -- КНОПКИ
    ReachBtn.MouseButton1Click:Connect(function()
        ReachActive = not ReachActive
        ReachBtn.Text = "REACH (15st): " .. (ReachActive and "ON" or "OFF")
        ReachBtn.BackgroundColor3 = ReachActive and Color3.fromRGB(0, 140, 70) or Color3.fromRGB(30, 30, 45)
        ApplyGrip()
    end)

    AuraBtn.MouseButton1Click:Connect(function()
        AuraActive = not AuraActive
        AuraBtn.Text = "KILL AURA: " .. (AuraActive and "ON" or "OFF")
        AuraBtn.BackgroundColor3 = AuraActive and Color3.fromRGB(140, 20, 20) or Color3.fromRGB(30, 30, 45)
    end)

    EspBtn.MouseButton1Click:Connect(function()
        EspActive = not EspActive
        EspBtn.Text = "PLAYER ESP: " .. (EspActive and "ON" or "OFF")
        EspBtn.BackgroundColor3 = EspActive and Color3.fromRGB(0, 80, 170) or Color3.fromRGB(30, 30, 45)
        UpdateEsp()
    end)
end)

if not success then
    warn("Ошибка загрузки: " .. tostring(err))
end
