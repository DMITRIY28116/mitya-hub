-- Fox Slap Combo: Item ESP + Kill Aura + Reach + Player ESP
if not game:IsLoaded() then game.Loaded:Wait() end
task.wait(2)

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local VirtualUser = game:GetService("VirtualUser")
local Workspace = game:GetService("Workspace")

local LocalPlayer = Players.LocalPlayer

-- AURA/REACH ПЕРЕМЕННЫЕ
local ReachActive = false
local AuraActive = false
local PlayerEspActive = false
local ReachDistance = 15 

-- ITEM ESP ПЕРЕМЕННЫЕ
local ItemEspActive = false
local SELECTIONBOX_NAME = "Exec_SelectionBox"
local BILLBOARD_NAME = "Exec_Billboard"
local TEXT_SIZE = 18
local GOLD_COLOR = Color3.fromRGB(255, 200, 0)
local DEFAULT_TEXT_COLOR = Color3.fromRGB(255, 255, 255)
local prioritized = {
    ["bull's essence"] = true,
    ["true power"] = true,
    ["potion of strength"] = true,
    ["boba"] = true,
}
local itemVisuals = {}
local itemEspConns = {}

-- ========================================================
-- AURA/REACH/PLAYER ESP ЛОГИКА
-- ========================================================
local OriginalGripC0 = nil

local function ApplyGrip()
    pcall(function()
        local char = LocalPlayer.Character
        if not char then return end
        local arm = char:FindFirstChild("Right Arm") or char:FindFirstChild("RightHand")
        if not arm then return end
        local grip = arm:FindFirstChild("RightGrip")
        if grip then
            if not OriginalGripC0 then OriginalGripC0 = grip.C0 end
            if ReachActive then
                grip.C0 = OriginalGripC0 * CFrame.new(0, 0, -ReachDistance)
            elseif OriginalGripC0 then
                grip.C0 = OriginalGripC0
            end
        end
    end)
end

local function OnCharacterAdded(char)
    task.wait(1)
    local arm = char:WaitForChild("Right Arm", 5) or char:WaitForChild("RightHand", 5)
    if arm then
        arm.ChildAdded:Connect(function(child)
            if child.Name == "RightGrip" then
                task.wait(0.1)
                OriginalGripC0 = nil
                ApplyGrip()
            end
        end)
    end
end

if LocalPlayer.Character then OnCharacterAdded(LocalPlayer.Character) end
LocalPlayer.CharacterAdded:Connect(OnCharacterAdded)

RunService.RenderStepped:Connect(function()
    if not AuraActive then return end
    pcall(function()
        local char = LocalPlayer.Character
        if not char or not char:FindFirstChild("HumanoidRootPart") then return end
        local myRoot = char.HumanoidRootPart
        
        for _, player in ipairs(Players:GetPlayers()) do
            if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
                local targetRoot = player.Character.HumanoidRootPart
                local dist = (myRoot.Position - targetRoot.Position).Magnitude
                
                if dist <= (ReachDistance + 2) then
                    VirtualUser:CaptureController()
                    VirtualUser:ClickButton1(Vector2.new())
                    break
                end
            end
        end
    end)
end)

local function UpdatePlayerEsp()
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            pcall(function()
                if player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
                    local highlight = player.Character:FindFirstChild("FoxESP")
                    if PlayerEspActive then
                        if not highlight then
                            highlight = Instance.new("Highlight")
                            highlight.Name = "FoxESP"
                            highlight.FillColor = Color3.fromRGB(255, 0, 0)
                            highlight.FillTransparency = 0.5
                            highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
                            highlight.OutlineTransparency = 0
                            highlight.Parent = player.Character
                        end
                    else
                        if highlight then highlight:Destroy() end
                    end
                end
            end)
        end
    end
end

Players.PlayerAdded:Connect(function(player)
    player.CharacterAdded:Connect(function(char) task.wait(2) UpdatePlayerEsp() end)
end)
Players.PlayerRemoving:Connect(function(player)
    pcall(function()
        if player.Character and player.Character:FindFirstChild("FoxESP") then player.Character.FoxESP:Destroy() end
    end)
end)
LocalPlayer.CharacterAdded:Connect(function() task.wait(2) UpdatePlayerEsp() end)


-- ========================================================
-- ITEM ESP ЛОГИКА (ОРИГИНАЛЬНАЯ)
-- ========================================================
local function isBasePart(obj) return obj and obj:IsA("BasePart") end

local function getAttachPartForModel(model)
    if not model or not model:IsA("Model") then return nil end
    if model.PrimaryPart and isBasePart(model.PrimaryPart) then return model.PrimaryPart end
    for _, d in ipairs(model:GetDescendants()) do
        if isBasePart(d) then return d end
    end
    return nil
end

local function safeNew(className)
    local ok, inst = pcall(Instance.new, className)
    if ok then return inst end
    return nil
end

local function destroyVisualsForPart(part)
    local entry = itemVisuals[part]
    if not entry then return end
    for _, obj in ipairs(entry) do
        pcall(function() if obj and obj.Parent then obj:Destroy() end end)
    end
    itemVisuals[part] = nil
end

local function createSelectionBox(part, useGold)
    local sb = safeNew("SelectionBox")
    if not sb then return nil end
    sb.Name = SELECTIONBOX_NAME
    pcall(function() sb.Adornee = part end)
    sb.LineThickness = 0.06
    sb.SurfaceTransparency = 1
    sb.Color3 = useGold and GOLD_COLOR or Color3.fromRGB(255, 170, 0)
    local ok, err = pcall(function() sb.Parent = Workspace end)
    if not ok then
        pcall(function() sb:Destroy() end)
        return nil
    end
    return sb
end

local function createBillboard(part, labelText, useGold)
    local bg = safeNew("BillboardGui")
    if not bg then return nil end
    bg.Name = BILLBOARD_NAME
    pcall(function() bg.Adornee = part end)
    bg.AlwaysOnTop = true
    bg.Size = UDim2.new(0, 160, 0, 28)
    bg.StudsOffset = Vector3.new(0, (part.Size.Y or 2) / 2 + 0.9, 0)
    bg.MaxDistance = 1000
    bg.LightInfluence = 0
    local ok, err = pcall(function() bg.Parent = LocalPlayer:WaitForChild("PlayerGui") end)
    if not ok then
        pcall(function() bg:Destroy() end)
        return nil
    end

    local label = safeNew("TextLabel")
    if not label then
        pcall(function() bg:Destroy() end)
        return nil
    end
    label.Name = "Label"
    label.Size = UDim2.new(1, 0, 1, 0)
    label.Position = UDim2.new(0, 0, 0, 0)
    label.BackgroundTransparency = 1
    label.Text = labelText or part.Name
    label.TextColor3 = useGold and GOLD_COLOR or DEFAULT_TEXT_COLOR
    label.TextStrokeColor3 = Color3.fromRGB(0,0,0)
    label.TextStrokeTransparency = 0
    label.Font = Enum.Font.GothamBold
    label.TextScaled = false
    label.TextSize = TEXT_SIZE
    label.Parent = bg

    part:GetPropertyChangedSignal("Size"):Connect(function()
        if bg and bg.Parent then bg.StudsOffset = Vector3.new(0, part.Size.Y / 2 + 0.9, 0) end
    end)

    part:GetPropertyChangedSignal("Name"):Connect(function()
        if label and label.Parent then label.Text = labelText or part.Name end
    end)

    return bg
end

local function createVisualsForAttach(part, labelText)
    if not isBasePart(part) then return end
    if itemVisuals[part] then return end

    local nameLower = (labelText or part.Name):lower()
    local useGold = prioritized[nameLower] == true
    local created = {}

    local sb = createSelectionBox(part, useGold)
    if sb then table.insert(created, sb) end

    local bb = createBillboard(part, labelText, useGold)
    if bb then table.insert(created, bb) end

    if #created > 0 then itemVisuals[part] = created end
end

local function applyToInstance(inst)
    if not inst then return end
    if inst:IsA("Model") then
        local attach = getAttachPartForModel(inst)
        if attach then createVisualsForAttach(attach, inst.Name) end
    elseif isBasePart(inst) then
        createVisualsForAttach(inst, inst.Name)
    end
end

local function EnableItemEsp()
    local folder = Workspace:FindFirstChild("items") or Workspace:FindFirstChild("Items")
    if not folder then return end
    
    for _, child in ipairs(folder:GetChildren()) do
        pcall(function() applyToInstance(child) end)
    end

    if itemEspConns.descAdded then itemEspConns.descAdded:Disconnect() end
    if itemEspConns.descRemoving then itemEspConns.descRemoving:Disconnect() end

    itemEspConns.descAdded = folder.DescendantAdded:Connect(function(desc)
        task.wait(0.03)
        pcall(function() applyToInstance(desc) end)
    end)

    itemEspConns.descRemoving = folder.DescendantRemoving:Connect(function(desc)
        if desc:IsA("BasePart") then
            destroyVisualsForPart(desc)
        elseif desc:IsA("Model") then
            local attach = getAttachPartForModel(desc)
            if attach then destroyVisualsForPart(attach) end
        end
    end)
end

local function DisableItemEsp()
    if itemEspConns.descAdded then itemEspConns.descAdded:Disconnect() itemEspConns.descAdded = nil end
    if itemEspConns.descRemoving then itemEspConns.descRemoving:Disconnect() itemEspConns.descRemoving = nil end
    
    for part, _ in pairs(itemVisuals) do
        destroyVisualsForPart(part)
    end
    itemVisuals = {}
end


